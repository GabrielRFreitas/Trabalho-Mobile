<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/reservation_selected" />
            <stroke
                android:width="1dp"
                android:color="@color/reservation_primary" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/reservation_panel" />
            <stroke
                android:width="1dp"
                android:color="@color/reservation_outline" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</selector>
