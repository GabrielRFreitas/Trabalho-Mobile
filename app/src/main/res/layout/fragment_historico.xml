<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragmentHistoricoRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/reservation_header"
    tools:context=".HistoricoFragment">

    <TextView
        android:id="@+id/historyTitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="29dp"
        android:text="Histórico"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/historyPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="58dp"
        android:background="@drawable/bg_reservation_panel"
        android:paddingStart="16dp"
        android:paddingTop="22dp"
        android:paddingEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/historyHeadingText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Reservas finalizadas"
            android:textColor="@color/reservation_text"
            android:textSize="19sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/historySubtitleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Consulte pagamentos e reservas anteriores"
            android:textColor="@color/reservation_muted"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/historyHeadingText" />

        <ScrollView
            android:id="@+id/historyScroll"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="18dp"
            android:clipToPadding="false"
            android:paddingBottom="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/historySubtitleText">

            <LinearLayout
                android:id="@+id/historyCardsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/historyCardOne"
                    android:layout_width="match_parent"
                    android:layout_height="126dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_home_card"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/historyOneName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Estacionamento Central"
                        android:textColor="@color/reservation_text"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/historyOneStatus"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/historyOneStatus"
                        android:layout_width="82dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_history_completed"
                        android:gravity="center"
                        android:text="Finalizada"
                        android:textColor="@color/reservation_primary_dark"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/historyOneDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="15 Abril 15:30 - 16:30"
                        android:textColor="@color/reservation_muted"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/historyOneName" />

                    <TextView
                        android:id="@+id/historyOneVehicle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Vaga: Carro"
                        android:textColor="@color/reservation_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/historyOneDate" />

                    <TextView
                        android:id="@+id/historyOnePrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R$17,00"
                        android:textColor="@color/reservation_text"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/historyOneVehicle"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/historyOneVehicle" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/historyCardTwo"
                    android:layout_width="match_parent"
                    android:layout_height="126dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_home_card"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/historyTwoName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Shopping Norte"
                        android:textColor="@color/reservation_text"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/historyTwoStatus"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/historyTwoStatus"
                        android:layout_width="82dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_history_completed"
                        android:gravity="center"
                        android:text="Finalizada"
                        android:textColor="@color/reservation_primary_dark"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/historyTwoDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="12 Abril 10:00 - 12:00"
                        android:textColor="@color/reservation_muted"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/historyTwoName" />

                    <TextView
                        android:id="@+id/historyTwoVehicle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Vaga: Moto"
                        android:textColor="@color/reservation_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/historyTwoDate" />

                    <TextView
                        android:id="@+id/historyTwoPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R$22,00"
                        android:textColor="@color/reservation_text"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/historyTwoVehicle"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/historyTwoVehicle" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/historyCardThree"
                    android:layout_width="match_parent"
                    android:layout_height="126dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_home_card"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/historyThreeName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Garagem Avenida"
                        android:textColor="@color/reservation_text"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/historyThreeStatus"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/historyThreeStatus"
                        android:layout_width="82dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_history_cancelled"
                        android:gravity="center"
                        android:text="Cancelada"
                        android:textColor="@color/reservation_danger_dark"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/historyThreeDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="08 Abril 18:00 - 19:00"
                        android:textColor="@color/reservation_muted"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/historyThreeName" />

                    <TextView
                        android:id="@+id/historyThreeVehicle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Vaga: Carro"
                        android:textColor="@color/reservation_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/historyThreeDate" />

                    <TextView
                        android:id="@+id/historyThreePrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R$15,00"
                        android:textColor="@color/reservation_text"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/historyThreeVehicle"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/historyThreeVehicle" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
