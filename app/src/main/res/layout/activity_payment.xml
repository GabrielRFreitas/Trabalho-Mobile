<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/paymentRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/reservation_header"
    tools:context=".PaymentActivity">

    <ImageButton
        android:id="@+id/paymentBackButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Voltar"
        android:padding="12dp"
        android:scaleType="center"
        android:src="@drawable/ic_arrow_back_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/paymentTitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="29dp"
        android:text="Pagamento"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/paymentPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="58dp"
        android:background="@drawable/bg_reservation_panel"
        android:paddingStart="16dp"
        android:paddingTop="22dp"
        android:paddingEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/summaryCard"
            android:layout_width="378dp"
            android:layout_height="193dp"
            android:background="@drawable/bg_payment_summary"
            android:paddingStart="14dp"
            android:paddingTop="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/summaryTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Resumo da reserva"
                android:textColor="@color/reservation_text"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/placeIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="18dp"
                android:layout_marginTop="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_location_pin_24"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/summaryTitle"
                app:tint="@color/reservation_primary" />

            <TextView
                android:id="@+id/placeText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Estacionamento Central"
                android:textColor="@color/reservation_text"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="@id/placeIcon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/placeIcon"
                app:layout_constraintTop_toTopOf="@id/placeIcon" />

            <ImageView
                android:id="@+id/paymentTimeIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginTop="14dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_clock_24"
                app:layout_constraintStart_toStartOf="@id/placeIcon"
                app:layout_constraintTop_toBottomOf="@id/placeIcon"
                app:tint="@color/reservation_primary" />

            <TextView
                android:id="@+id/paymentDateTimeText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="15 Abril 15:30 - 16:30"
                android:textColor="@color/reservation_text"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="@id/paymentTimeIcon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/paymentTimeIcon"
                app:layout_constraintTop_toTopOf="@id/paymentTimeIcon" />

            <ImageView
                android:id="@+id/paymentCarIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginTop="14dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_car_24"
                app:layout_constraintStart_toStartOf="@id/paymentTimeIcon"
                app:layout_constraintTop_toBottomOf="@id/paymentTimeIcon"
                app:tint="@color/reservation_primary" />

            <TextView
                android:id="@+id/paymentSpotText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Vaga: Carro"
                android:textColor="@color/reservation_text"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="@id/paymentCarIcon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/paymentCarIcon"
                app:layout_constraintTop_toTopOf="@id/paymentCarIcon" />

            <TextView
                android:id="@+id/totalLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Valor Total"
                android:textColor="@color/reservation_text"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/totalValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$17,00"
                android:textColor="@color/reservation_text"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/totalLabel"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/totalLabel" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/paymentMethodLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Forma de pagamento"
            android:textColor="@color/reservation_text"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/summaryCard" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/pixMethod"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_payment_method_selected"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/paymentMethodLabel">

            <ImageView
                android:id="@+id/pixIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="14dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_pix_24"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/reservation_primary" />

            <TextView
                android:id="@+id/pixText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:text="Pix"
                android:textColor="@color/reservation_text"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/pixRadio"
                app:layout_constraintStart_toEndOf="@id/pixIcon"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/pixRadio"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="14dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_radio_selected"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardMethod"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_reservation_row"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pixMethod">

            <ImageView
                android:id="@+id/cardIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="14dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_credit_card_24"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/reservation_primary" />

            <TextView
                android:id="@+id/cardText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:text="Cartão de crédito"
                android:textColor="@color/reservation_text"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/cardRadio"
                app:layout_constraintStart_toEndOf="@id/cardIcon"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/cardRadio"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="14dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_radio_unselected"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/walletMethod"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_reservation_row"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardMethod">

            <ImageView
                android:id="@+id/walletIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="14dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_wallet_24"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/reservation_primary" />

            <TextView
                android:id="@+id/walletText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:text="Carteira digital"
                android:textColor="@color/reservation_text"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/walletRadio"
                app:layout_constraintStart_toEndOf="@id/walletIcon"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/walletRadio"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="14dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_radio_unselected"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/payButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_reservation_button"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:drawableStart="@drawable/ic_lock_24"
            android:drawablePadding="8dp"
            android:drawableTint="@color/white"
            android:text="Pagar R$17,00"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
